ALPACA_API_KEY=your_api_key_here
ALPACA_API_SECRET=your_api_secret_here
PAPER=true
SYMBOLS=AAPL,MSFT,NVDA

# EMA crossover
SHORT_WINDOW=9
LONG_WINDOW=21

# RSI filter
RSI_WINDOW=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30

# Additional filters
VOLUME_WINDOW=20
TREND_EMA=200
MACD_FAST=12
MACD_SLOW=26
MACD_SIGN=9

# Risk management
MAX_POSITION_PCT=0.05
MAX_DAILY_LOSS_PCT=0.02
STOP_LOSS_PCT=0.02
